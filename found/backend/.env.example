# 项目根目录环境变量配置示例
# 复制此文件并重命名为 .env，然后填入实际值

# 通义千问API-Key（用于前端）
VITE_AI_API_KEY=your_tongyi_api_key_here

# 后端使用的通义千问API密钥
AI_API_KEY=your_tongyi_api_key_here

# 通义千问API基础URL（可选，默认使用阿里云DashScope）
AI_API_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/text-embedding/text-embedding

# 智谱AI API密钥（已替换为Trae大模型）
VITE_ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_API_KEY=your_zhipu_api_key_here

# Trae大模型API密钥
VITE_TRAE_API_KEY=your_trae_api_key_here
TRAE_API_KEY=your_trae_api_key_here

# MongoDB连接字符串
MONGO_URI=mongodb://localhost:27017/learning-ai-platform

# JWT密钥（必填！建议替换为随机字符串，比如用 uuid 生成，增强安全性）
JWT_SECRET=your_jwt_secret_key_secure
JWT_EXPIRES_IN=30d
