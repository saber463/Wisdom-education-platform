    "test:coverage": "jest --coverage",
    "sync:check": "tsx scripts/check-data-consistency.ts",
    "sync:manual": "tsx scripts/sync-databases.ts",
    "sync:auto": "tsx scripts/start-auto-sync.ts"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.9.13",
    "@grpc/proto-loader": "^0.7.10",
    "@types/compression": "^1.8.1",
    "@types/mongoose": "^5.11.96",
    "axios": "^1.13.6",
    "bcrypt": "^5.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.1.5",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "node-cron": "^4.2.1",
    "redis": "^4.7.1",
    "winston": "^3.11.0",
    "xss-clean": "^0.1.4"
