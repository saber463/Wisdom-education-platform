# 客户端环境变量配置示例
# 复制此文件并重命名为 .env，然后填入实际值

# 后端API基础URL
VITE_API_BASE_URL=http://localhost:4001/api

# 存储前缀（用于localStorage）
VITE_STORAGE_PREFIX=learning-ai-platform

# 通义千问API-Key（用于前端AI功能）
VITE_AI_API_KEY=your_tongyi_api_key_here

# 智谱AI API密钥
VITE_ZHIPU_API_KEY=your_zhipu_api_key_here

# Trae大模型API密钥
VITE_TRAE_API_KEY=your_trae_api_key_here

# 开发环境是否启用控制台日志
VITE_ENABLE_DEBUG_LOG=true
