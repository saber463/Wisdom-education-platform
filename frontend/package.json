    "echarts": "^5.4.3",
    "element-plus": "^2.5.0",
    "pinia": "^2.1.7",
    "video.js": "^8.23.4",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
