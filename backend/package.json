{
  "name": "edu-education-platform-backend",
  "version": "1.0.0",
  "description": "智慧教育学习平台后端服务",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts --fix",
    "test": "jest --verbose",
    "test:fast": "jest --config=jest.config.fast.js --verbose",
